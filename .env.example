# ampersend agent credentials
# Run `pnpm bootstrap` to set up automatically, or fill in manually.
# Bootstrap writes AMPERSEND_AGENT_ACCOUNT after approval completes.
AMPERSEND_AGENT_KEY=0x...
# AMPERSEND_AGENT_ACCOUNT=0x... # set automatically after `pnpm bootstrap finish`

# Optional overrides (only needed in advanced setups):
# AMPERSEND_API_URL=https://api.ampersend.ai
# AMPERSEND_NETWORK=base                            # base | base-sepolia
# AMPERSEND_CHAIN_ID=8453                            # 8453 (base) | 84532 (base-sepolia)
# AMPERSEND_MCP_PROXY_PORT=3000                      # MCP proxy listen port
#
# If .env lives outside this folder:
# AMPERSEND_ENV_FILE=/full/path/to/.env
# HERMES_CONFIG_DIR=~/.hermes
